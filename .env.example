# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=farman-bot@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
# The account ID or email address that tickets get assigned to
JIRA_BOT_USER=farman-bot@yourcompany.com
JIRA_POLL_INTERVAL_SECONDS=30
JIRA_DONE_TRANSITION=Done
JIRA_IN_PROGRESS_TRANSITION=In Progress

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Keep true until you're confident — generates & previews, never executes
DRY_RUN_MODE=true
APPROVAL_TIMEOUT_MINUTES=60
# Comma-separated Jira account IDs / emails allowed to /approve
AUTHORIZED_APPROVERS=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///farman.db
